{
  "name": "omnigraph",
  "version": "1.3.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "omnigraph": "packages/cli/dist/index.js"
  },
  "scripts": {
    "build": "npm run build -w @omnigraph/types && npm run build -w @omnigraph/parsers && npm run build -w @omnigraph/server && npm run build -w @omnigraph/cli && npm run build -w @omnigraph/ui",
    "dev": "node packages/cli/dist/index.js",
    "test": "vitest run",
    "bundle": "node scripts/bundle.js"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "esbuild": "^0.27.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.1"
  }
}
